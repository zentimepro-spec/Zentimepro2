generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SALES
}

enum LeadStatus {
  NOVO
  CONTATO_INICIADO
  QUALIFICADO
  PROPOSTA_ENVIADA
  NEGOCIACAO
  FECHADO
  PERDIDO
}

enum LeadSource {
  SITE
  WHATSAPP
  INSTAGRAM
  GOOGLE
  INDICACAO
  OUTRO
}

enum LeadPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum ActivityType {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  OWNER_CHANGED
  CONTACTED
  PROPOSAL_SENT
  FINANCIAL_UPDATED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String
  role          UserRole       @default(SALES)
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  assignedLeads Lead[]         @relation("LeadOwner")
  notes         LeadNote[]
  activities    LeadActivity[]
  monthlyGoals  UserMonthlyGoal[]
}

model Lead {
  id                String         @id @default(cuid())
  nome              String
  empresa           String
  telefone          String
  email             String
  servico           String
  mensagem          String
  status            LeadStatus     @default(NOVO)
  source            LeadSource     @default(SITE)
  priority          LeadPriority   @default(MEDIA)
  sourceDetail      String?
  internalNotes     String?
  lostReason        String?
  budgetValue       Decimal?       @db.Decimal(10, 2)
  closedServiceValue Decimal?      @db.Decimal(10, 2)
  contactedAt       DateTime?
  closedAt          DateTime?
  lastInteractionAt DateTime?
  nextAction        String?
  nextActionAt      DateTime?
  assignedToId      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  assignedTo        User?          @relation("LeadOwner", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes             LeadNote[]
  activities        LeadActivity[]
  additions         LeadAddition[]

  @@index([status, createdAt])
  @@index([status, closedAt])
  @@index([source, createdAt])
  @@index([servico, createdAt])
  @@index([priority, createdAt])
  @@index([assignedToId])
  @@index([closedAt])
}

model LeadNote {
  id        String   @id @default(cuid())
  content   String
  leadId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model LeadActivity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String
  leadId      String
  actorId     String?
  createdAt   DateTime     @default(now())
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor       User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([actorId])
}

model LeadAddition {
  id          String   @id @default(cuid())
  leadId       String
  description String
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model UserMonthlyGoal {
  id           String   @id @default(cuid())
  userId       String
  monthDate    DateTime
  revenueGoal  Decimal? @db.Decimal(10, 2)
  wonLeadsGoal Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthDate])
  @@index([monthDate])
}
